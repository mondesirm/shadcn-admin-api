model User {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName   String
  lastName    String
  username    String     @unique
  email       String     @unique
  phoneNumber String?
  role        UserRole   @default(cashier)
  status      UserStatus @default(inactive)
  tasks       Task[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
}

enum UserStatus {
  active
  inactive
  invited
  suspended
}

enum UserRole {
  superadmin
  admin
  manager
  cashier
}
